# DaoPai V2 环境变量示例
#
# 使用方法：
#   cp .env.example .env
#   然后填入本机真实值
#
# 注意：
#   - .env 已在 .gitignore 中，不会被提交
#   - 真实账号密码严禁写入 Git
#   - PowerShell 环境变量优先于 .env（同名变量以 PowerShell 为准）

# ── Runtime 模式 ──
# V2 Phase 4-A 起推荐测试模式：playwright（真实 Chrome）
# 回退模式：legacy_easybr（旧 EasyBR 路径，保留为备用）
WINDOW_RUNTIME_MODE=playwright

# ── 测试账号（仅本机使用，不要提交真实值）──
# 通过环境变量传递，严禁硬编码到代码或日志
BNSY_TEST_USERNAME=
BNSY_TEST_PASSWORD=

# ── PostgreSQL 连接（V2 独立实例，端口 5435）──
PG_HOST=127.0.0.1
PG_PORT=5435
PG_USER=daopai
PG_PASSWORD=daopai_secret
PG_DATABASE=daopai_next
PG_POOL_MAX=20

# ── 服务端口 ──
# V2 后端默认 3200（V1 为 3100，完全隔离）
# PORT=3200

# ── 运行环境 ──
# production 时使用 SQLite，development 时使用 JSON 文件
# NODE_ENV=development
